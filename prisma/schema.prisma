generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model categorias_gastos {
  id            Int             @id @default(autoincrement())
  nombre        String          @db.VarChar(50)
  tipo          String          @db.VarChar(20)
  descripcion   String?         @db.VarChar(200)
  transacciones transacciones[]
}

model cuentas {
  id            Int             @id @default(autoincrement())
  usuario_id    Int?
  saldo_actual  Decimal?        @default(0.00) @db.Decimal(10, 2)
  meta_ahorro   Decimal?        @default(0.00) @db.Decimal(10, 2)
  usuarios      usuarios?       @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  transacciones transacciones[]
}

model transacciones {
  id                Int                @id @default(autoincrement())
  cuenta_id         Int?
  categoria_id      Int?
  monto             Decimal            @db.Decimal(10, 2)
  fecha             DateTime?          @default(now()) @db.Timestamp(6)
  categorias_gastos categorias_gastos? @relation(fields: [categoria_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  cuentas           cuentas?           @relation(fields: [cuenta_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model usuarios {
  id             Int       @id @default(autoincrement())
  nombre         String    @db.VarChar(100)
  email          String    @unique @db.VarChar(100)
  fecha_registro DateTime? @default(now()) @db.Timestamp(6)
  cuentas        cuentas[]
}
